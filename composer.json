{
    "name": "sertxudeveloper/laravel-translations-checker",
    "description": "Check Laravel translation files for missing keys, files, and empty values. Integrates with CI/CD pipelines.",
    "keywords": [
        "laravel",
        "translations",
        "i18n",
        "checker"
    ],
    "homepage": "https://github.com/sertxudeveloper/laravel-translations-checker",
    "license": "MIT",
    "authors": [
        {
            "name": "Sergio Peris",
            "email": "dev.sertxu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "SertxuDeveloper\\TranslationsChecker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SertxuDeveloper\\TranslationsChecker\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan",
        "format": "vendor/bin/pint --test",
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SertxuDeveloper\\TranslationsChecker\\TranslationsCheckerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
